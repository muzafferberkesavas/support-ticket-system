# ─────────────────────────────────────────────────────────────
# Support Ticket System — Environment Variables
#
# Bu dosya geliştirme için güvenli varsayılan değerlerle repoya dahildir;
# böylece proje klonlandıktan sonra doğrudan `docker compose up --build`
# ile çalışır. Gerçek bir ortamda JWT_SECRET gibi değerleri değiştirin.
# (Kişisel override için .env.local kullanın; o git'e dahil edilmez.)
# ─────────────────────────────────────────────────────────────

# Database (backend, postgres servisine servis adıyla bağlanır)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_db

# Auth (JWT)
JWT_SECRET=super_secret_dev_key_change_me
JWT_EXPIRES_IN=7d

# Backend
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Seed admin hesabı (ilk açılışta otomatik oluşturulur)
ADMIN_EMAIL=admin@support.local
ADMIN_PASSWORD=Admin123!

# Redis (Socket.IO real-time adapter)
REDIS_URL=redis://redis:6379

# ── E-posta (gerçek SMTP) ──
# Production SMTP kullanılır (Mailpit kaldırıldı). Gmail örneği aşağıda.
# Gizli bilgiler (SMTP_USER / SMTP_PASS) repoya KOYULMAZ; .env.local içine yazılır
# ve şu komutla yüklenir:
#   docker compose --env-file .env --env-file .env.local up -d --build
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Destek Merkezi <no-reply@support.local>
APP_URL=http://localhost:5173

# Worker (Bull) — cron / zamanlama ayarları
DIGEST_CRON=0 8 * * *          # günlük özet (her gün 08:00)
SLA_SWEEP_CRON=*/2 * * * *     # SLA eskalasyon + bayat talep taraması (her 2 dk)
STALE_TICKET_DAYS=3            # kaç günden eski açık talep "bayat" sayılır
CSAT_DELAY_MS=3600000          # talep kapanınca CSAT maili gecikmesi (1 saat)
# Bull Board (kuyruk paneli) — http://localhost:3001/admin/queues
BULLBOARD_PORT=3001
BULLBOARD_USER=admin
BULLBOARD_PASS=Admin123!

# Dosya yükleme (ekler)
MAX_UPLOAD_MB=10

# Frontend → backend URL (build'e gömülür, tarayıcı tarafından kullanılır)
VITE_API_URL=http://localhost:3000
