# ─────────────────────────────────────────────────────────────
# Support Ticket System — Environment Variables
#
# Bu dosya geliştirme için güvenli varsayılan değerlerle repoya dahildir;
# böylece proje klonlandıktan sonra doğrudan `docker compose up --build`
# ile çalışır. Gerçek bir ortamda JWT_SECRET gibi değerleri değiştirin.
# (Kişisel override için .env.local kullanın; o git'e dahil edilmez.)
# ─────────────────────────────────────────────────────────────

# Database (backend, postgres servisine servis adıyla bağlanır)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_db

# Auth (JWT)
JWT_SECRET=super_secret_dev_key_change_me
JWT_EXPIRES_IN=7d

# Backend
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Seed admin hesabı (ilk açılışta otomatik oluşturulur)
ADMIN_EMAIL=admin@support.local
ADMIN_PASSWORD=Admin123!

# Redis (Socket.IO real-time adapter)
REDIS_URL=redis://redis:6379

# E-posta (Mailpit dev SMTP — web arayüzü http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=Destek Merkezi <no-reply@support.local>
APP_URL=http://localhost:5173
# SMTP kimlik doğrulama (Mailpit için boş). Gerçek bir sunucu için doldurun.
#   Gmail örneği: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false,
#   SMTP_USER=adresiniz@gmail.com, SMTP_PASS=<16 haneli Uygulama Şifresi>
#   (Gmail'de 2FA açıkken "App Password" oluşturmanız gerekir.)
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# Worker (Bull) — günlük özet cron'u (varsayılan her gün 08:00)
DIGEST_CRON=0 8 * * *

# Dosya yükleme (ekler)
MAX_UPLOAD_MB=10

# Frontend → backend URL (build'e gömülür, tarayıcı tarafından kullanılır)
VITE_API_URL=http://localhost:3000
