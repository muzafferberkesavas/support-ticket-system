# ─────────────────────────────────────────────────────────────
# Support Ticket System — Environment Variables
# Copy this file to `.env` before running `docker compose up --build`
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database (backend connects to the `postgres` service by name) ──
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_db

# ── Auth (JWT) ──
# CHANGE THIS to a long random string in any real environment.
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Backend ──
PORT=3000
# Allowed frontend origin(s), comma-separated.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ── Seed admin account (created automatically on first startup) ──
ADMIN_EMAIL=admin@support.local
ADMIN_PASSWORD=Admin123!

# ── Redis (Socket.IO real-time adapter) ──
REDIS_URL=redis://redis:6379

# ── E-mail (Mailpit dev SMTP — web UI at http://localhost:8025) ──
# For real e-mail, point these at your SMTP provider.
SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=Destek Merkezi <no-reply@support.local>
# Used to build password-reset links in e-mails (the frontend URL).
APP_URL=http://localhost:5173

# ── File uploads (attachments) ──
MAX_UPLOAD_MB=10

# ── Frontend → backend URL (baked into the Vue build, used by the browser) ──
VITE_API_URL=http://localhost:3000
