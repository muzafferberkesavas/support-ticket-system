# ─────────────────────────────────────────────────────────────
# Support Ticket System — Ortam Değişkenleri (ÖRNEK / ŞABLON)
#
# Kurulum:
#   cp .env.example .env
# Ardından `docker compose up -d --build` ile çalışır.
#
# Aşağıdaki varsayılanlar YEREL geliştirme için güvenlidir. GERÇEK bir ortamda
# en azından şu değerleri değiştirin: JWT_SECRET, ADMIN_PASSWORD, BULLBOARD_PASS.
# Gizli bilgileri (SMTP_USER / SMTP_PASS gibi) .env.local içine yazın; o git'e
# dahil edilmez ve şu komutla yüklenir:
#   docker compose --env-file .env --env-file .env.local up -d --build
# ─────────────────────────────────────────────────────────────

# Veritabanı (backend, postgres servisine servis adıyla bağlanır)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/support_db

# Kimlik doğrulama (JWT) — PROD'da JWT_SECRET'ı uzun rastgele bir değerle değiştirin
JWT_SECRET=super_secret_dev_key_change_me
JWT_EXPIRES_IN=7d

# Backend
PORT=3000
# HTTPS domain (proxy) + yerel geliştirme origin'leri
CORS_ORIGIN=https://support.local,http://localhost:5173,http://127.0.0.1:5173

# Seed admin hesabı (ilk açılışta otomatik oluşturulur) — PROD'da şifreyi değiştirin
ADMIN_EMAIL=admin@support.local
ADMIN_PASSWORD=Admin123!

# Redis (Socket.IO real-time adapter + Bull kuyruğu)
REDIS_URL=redis://redis:6379

# ── E-posta (gerçek SMTP) ──
# Gizli bilgiler (SMTP_USER / SMTP_PASS) BURAYA YAZILMAZ; .env.local içine yazılır.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Destek Merkezi <no-reply@support.local>
# E-postalardaki bağlantılar bu adresi kullanır (HTTPS domain).
APP_URL=https://support.local

# Worker (Bull) — cron / zamanlama ayarları
DIGEST_CRON=0 8 * * *          # günlük özet (her gün 08:00)
SLA_SWEEP_CRON=*/2 * * * *     # SLA eskalasyon + bayat talep taraması (her 2 dk)
STALE_TICKET_DAYS=3            # kaç günden eski açık talep "bayat" sayılır
CSAT_DELAY_MS=3600000          # talep kapanınca CSAT maili gecikmesi (1 saat)
# Bull Board (kuyruk paneli) — http://localhost:3001/admin/queues — PROD'da şifreyi değiştirin
BULLBOARD_PORT=3001
BULLBOARD_USER=admin
BULLBOARD_PASS=Admin123!

# Dosya yükleme (ekler)
MAX_UPLOAD_MB=10

# ── Dosya üretim mikroservisi (Excel/PDF) ──
# Backend/worker bu URL'ye HTTP isteği atar. Mikroservisin DB bağlantısı YOKTUR.
# Token boş bırakılırsa servis-içi auth devre dışıdır (yerel geliştirme).
FILE_SERVICE_URL=http://file-service:4000
FILE_SERVICE_TOKEN=

# Frontend → backend URL (build'e gömülür, tarayıcı tarafından kullanılır)
# HTTPS proxy üzerinden aynı origin: https://support.local/api → backend
VITE_API_URL=https://support.local/api
