{
  "name": "support-ticket-system",
  "version": "1.0.0",
  "private": true,
  "description": "Destek Talep Sistemi — Vue 3 + Express + PostgreSQL + dosya üretim mikroservisi (kök seviyesi geliştirme araçları: lint & format)",
  "scripts": {
    "lint": "eslint \"{backend,file-service}/src/**/*.ts\" \"frontend/src/**/*.{ts,vue}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"{backend,file-service,frontend}/src/**/*.{ts,vue}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"{backend,file-service,frontend}/src/**/*.{ts,vue}\""
  },
  "devDependencies": {
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "prettier": "^3.4.1",
    "typescript-eslint": "^8.16.0"
  }
}
