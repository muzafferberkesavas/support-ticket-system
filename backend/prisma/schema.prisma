// Prisma schema — Support Ticket System
// Database: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user // end-user (customer) — can only see their own tickets
  agent // support agent — handles tickets in their departments
  team_lead // department lead — manages their department(s)
  admin // full access across the whole system
}

enum Priority {
  low
  medium
  high
}

enum Status {
  open
  in_progress
  closed
}

model User {
  id                 String               @id @default(uuid())
  email              String               @unique
  password           String
  fullName           String?              @map("full_name")
  role               Role                 @default(user)
  mustChangePassword Boolean              @default(false) @map("must_change_password")
  createdAt          DateTime             @default(now()) @map("created_at")
  tickets            Ticket[] // tickets created by this user (as requester)
  replies            TicketReply[]
  memberships        DepartmentMember[] // departments this user belongs to (agents/leads)
  assignments        TicketAssignee[] // tickets assigned to this user
  notifications      Notification[]
  resetTokens        PasswordResetToken[]

  @@map("users")
}

model Notification {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String // reply | created | assigned | status
  ticketId      String?  @map("ticket_id")
  ticketSubject String   @map("ticket_subject")
  actor         String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Configurable SLA targets per priority (admin-editable).
model SlaPolicy {
  priority          String   @id // low | medium | high
  responseMinutes   Int      @map("response_minutes")
  resolutionMinutes Int      @map("resolution_minutes")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("sla_policies")
}

// Reusable staff reply templates (macros). departmentId null = global.
model CannedResponse {
  id           String   @id @default(uuid())
  title        String
  body         String
  createdById  String?  @map("created_by_id")
  departmentId String?  @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([departmentId])
  @@map("canned_responses")
}

model Attachment {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploaderId String?  @map("uploader_id")
  filename   String // original filename
  storedName String   @map("stored_name") // on-disk name
  mimeType   String   @map("mime_type")
  size       Int
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("attachments")
}

// Immutable activity/audit trail. No FK so history survives ticket/user deletion.
model AuditLog {
  id         String   @id @default(uuid())
  ticketId   String?  @map("ticket_id")
  actorId    String?  @map("actor_id")
  actorName  String?  @map("actor_name")
  action     String // ticket.created | ticket.status | ticket.assigned | ticket.reply | ticket.escalated | ...
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ticketId, createdAt])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model Department {
  id                String             @id @default(uuid())
  name              String             @unique
  description       String?
  autoAssignEnabled Boolean            @default(true) @map("auto_assign_enabled")
  createdAt         DateTime           @default(now()) @map("created_at")
  members           DepartmentMember[]
  tickets           Ticket[]

  @@map("departments")
}

// Join table: which users belong to which departments (agents / team leads).
model DepartmentMember {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  departmentId String     @map("department_id")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, departmentId])
  @@index([departmentId])
  @@map("department_members")
}

model Ticket {
  id           String           @id @default(uuid())
  subject      String
  message      String
  priority     Priority         @default(medium)
  status       Status           @default(open)
  category     String?
  tags         String[]         @default([])
  userId       String           @map("user_id") // requester
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId String?          @map("department_id") // target department (optional)
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignees    TicketAssignee[] // specific people handling this ticket
  replies      TicketReply[]
  attachments  Attachment[]
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  firstResponseAt DateTime?     @map("first_response_at") // first public staff reply
  resolvedAt      DateTime?     @map("resolved_at") // when moved to closed
  escalated       Boolean       @default(false)
  escalatedAt     DateTime?     @map("escalated_at")
  reminderSentAt  DateTime?     @map("reminder_sent_at") // last "stale ticket" reminder
  csatRating      Int?          @map("csat_rating") // 1-5 satisfaction
  csatComment     String?       @map("csat_comment")
  csatAt          DateTime?     @map("csat_at")

  @@index([userId])
  @@index([departmentId])
  @@index([status])
  @@index([priority])
  @@map("tickets")
}

// Join table: which agents are assigned to a ticket.
model TicketAssignee {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  userId     String   @map("user_id")
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@unique([ticketId, userId])
  @@index([userId])
  @@map("ticket_assignees")
}

model TicketReply {
  id         String   @id @default(uuid())
  ticketId   String   @map("ticket_id")
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  message    String
  isInternal Boolean  @default(false) @map("is_internal") // internal note vs customer-facing reply
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("ticket_replies")
}
